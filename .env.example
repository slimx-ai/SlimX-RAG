SLIMX_LLM_MODEL=ollama:llama3.2:3b
SLIMX_LLM_TIMEOUT=300
SLIMX_LLM_MAX_TOKENS=256
SLIMX_MAX_CONTEXT_CHARS=3000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

RAG_INDEX_BACKEND=local
RAG_INDEX_PATH=/data/index.jsonl
RAG_STATE_PATH=/data/index_state.json
# Embedder: hash (deterministic, non-semantic) | openai (cloud) | hf (local semantic,
# the image default). The Docker entrypoint builds + serves with this provider.
RAG_EMBED_PROVIDER=hf
RAG_EMBED_MODEL=text-embedding-3-small
RAG_HF_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBED_DIM=384
# Knowledge-base dir the entrypoint indexes on first start (container path). With the
# demo compose, set RAG_KB_DIR_HOST to mount your own corpus at /kb.
RAG_KB_DIR=/kb
RAG_TOP_K=5
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=slimx_demo

DEMO_AUTH_TOKEN=
